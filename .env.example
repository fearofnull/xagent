# 飞书机器人配置示例
# 复制此文件为 .env 并填入你的实际配置

# ============================================================
# 飞书应用配置（必需）
# ============================================================
# 飞书应用 ID（在飞书开放平台获取）
FEISHU_APP_ID=your_app_id_here

# 飞书应用密钥（在飞书开放平台获取）
FEISHU_APP_SECRET=your_app_secret_here

# ============================================================
# AI CLI 配置
# ============================================================
# 目标项目目录（用于 Claude Code CLI 和 Gemini CLI 执行代码操作）
# 示例：E:\IdeaProjects\your-project 或 /home/user/projects/your-project
TARGET_PROJECT_DIR=

# AI 执行超时时间（秒）
# 默认：600（10分钟）
# 说明：CLI 执行器等待 AI 响应的最长时间
AI_TIMEOUT=600

# Qwen Code CLI 专用目录（可选，留空则使用 TARGET_PROJECT_DIR）
# 说明：指定 Qwen Code CLI 操作的目标代码目录
# 安装：npm install -g @qwen-code/qwen-code
QWEN_CLI_TARGET_DIR=

# ============================================================
# 默认设置
# ============================================================
# 默认执行层
# 可选值：api（快速响应）, cli（深度代码能力）
# 默认：api
# 说明：当用户未指定执行层时使用的默认执行方式
# 注意：此配置可以通过动态配置系统在对话窗口中覆盖（使用 /layer 命令）
DEFAULT_LAYER=api

# CLI层专用默认提供商
# 可选值：claude, gemini（留空则自动检测）
# 默认：空（自动检测第一个可用的CLI执行器）
# 说明：当AI判断需要CLI层时，使用此提供商
#   - 如果不设置，系统会自动检测第一个可用的CLI执行器（优先级：claude > gemini）
#   - 适用场景：需要指定特定的CLI工具
#   - 示例：DEFAULT_CLI_PROVIDER=gemini（CLI层用Gemini）
# 注意：此配置可以通过动态配置系统在对话窗口中覆盖（使用 /cliprovider 命令）
DEFAULT_CLI_PROVIDER=

# ============================================================
# 动态配置系统
# ============================================================
# 说明：以下配置项可以在对话窗口中动态修改，无需重启服务
#
# 配置优先级（从高到低）：
#   1. 临时参数（--key=value，单次使用）
#   2. 会话配置（/setdir, /lang 等命令，持久化）
#   3. 全局配置（环境变量，本文件）
#   4. 默认值（系统默认）
#
# 会话类型：
#   - 私聊：配置基于 user_id（用户级别），每个用户独立配置
#   - 群聊：配置基于 chat_id（群组级别），群组成员共享配置
#
# 可动态配置的项目：
#   - TARGET_PROJECT_DIR: 使用 /setdir <path> 命令
#   - RESPONSE_LANGUAGE: 使用 /lang <code> 命令
#   - DEFAULT_LAYER: 使用 /layer <type> 命令
#   - DEFAULT_CLI_PROVIDER: 使用 /cliprovider <name> 命令
#
# 配置命令：
#   /setdir <path>        - 设置项目目录
#   /lang <code>          - 设置回复语言（zh-CN, en-US 等）
#   /layer <type>         - 设置默认执行层（api, cli）
#   /cliprovider <name>   - 设置CLI提供商（claude, gemini）
#   /config 或 配置       - 查看当前配置
#   /reset 或 重置配置    - 重置所有配置
#
# 临时参数（单次使用，不持久化）：
#   --dir=/path/to/project 查看项目结构
#   --lang=en-US What is AI?
#   --layer=api 解释量子计算
#
# 详细文档：docs/DYNAMIC_CONFIG.md
#
# ============================================================

# ============================================================
# 智能路由配置
# ============================================================
# 使用AI进行意图分类
# 可选值：true, false
# 默认：true
# 说明：启用后使用AI判断用户意图，决定是否需要CLI层
#   - true: 使用AI分类（推荐，更准确）
#   - false: 使用关键词检测（降级方案）
USE_AI_INTENT_CLASSIFICATION=true

# ============================================================
# 语言配置
# ============================================================
# AI回复语言
# 可选值：zh-CN（简体中文）, zh-TW（繁体中文）, en-US（英语）, ja-JP（日语）, ko-KR（韩语）等
# 默认：空（由AI根据用户输入自动判断）
# 说明：设置后，AI会被要求使用指定语言回复
#   - zh-CN: 中文（简体）
#   - zh-TW: 中文（繁體）
#   - en-US: English
#   - ja-JP: 日本語
#   - ko-KR: 한국어
#   - fr-FR: Français
#   - de-DE: Deutsch
#   - es-ES: Español
#   - 留空: 由AI自动判断使用什么语言
RESPONSE_LANGUAGE=

# ============================================================
# 会话管理配置
# ============================================================
# 会话存储路径
# 默认：./data/sessions.json
# 说明：会话数据的存储位置
SESSION_STORAGE_PATH=./data/sessions.json

# 单个会话最大消息数
# 默认：50
# 说明：超过此数量后自动创建新会话，避免上下文过长
MAX_SESSION_MESSAGES=50

# 会话超时时间（秒）
# 默认：86400（24小时）
# 说明：会话闲置超过此时间后自动过期
SESSION_TIMEOUT=86400

# ============================================================
# 缓存配置
# ============================================================
# 消息去重缓存大小
# 默认：1000
# 说明：用于防止重复处理相同消息的缓存容量
CACHE_SIZE=1000

# ============================================================
# SSL 配置（可选）
# ============================================================
# SSL 证书文件路径
# 默认：空（使用 certifi 提供的证书）
# 说明：自定义 SSL 证书路径，通常不需要配置
SSL_CERT_FILE=

# ============================================================
# 日志配置
# ============================================================
# 日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认：INFO
# 说明：控制日志输出的详细程度
#   - DEBUG: 最详细，包含调试信息
#   - INFO: 一般信息
#   - WARNING: 警告信息
#   - ERROR: 错误信息
#   - CRITICAL: 严重错误
LOG_LEVEL=INFO

# ============================================================
# 测试配置（仅用于测试脚本）
# ============================================================
# 测试用的飞书群聊 ID
# 说明：用于运行集成测试脚本时指定测试群聊
FEISHU_CHAT_ID=

# 测试用的飞书用户 ID
# 说明：用于运行集成测试脚本时指定测试用户
FEISHU_USER_ID=

# ============================================================
# Web 管理界面配置（可选）
# ============================================================
# 是否启用 Web 管理界面
# 可选值：true, false
# 默认：false
# 说明：启用后可通过浏览器访问 Web 管理界面
# 访问地址：http://localhost:8080
ENABLE_WEB_ADMIN=false

# Web 管理界面主机地址
# 默认：0.0.0.0
# 说明：Web 管理界面绑定的主机地址
#   - 0.0.0.0: 允许所有网络访问
#   - 127.0.0.1: 只允许本地访问
WEB_ADMIN_HOST=0.0.0.0

# Web 管理界面端口
# 默认：8080
# 说明：Web 管理界面监听的端口
WEB_ADMIN_PORT=8080

# Web 管理界面管理员密码
# 默认：admin123（仅开发环境）
# 说明：登录 Web 管理界面的密码
# 注意：生产环境请设置强密码
WEB_ADMIN_PASSWORD=

# JWT 密钥
# 默认：使用开发密钥（仅开发环境）
# 说明：用于生成和验证 JWT 令牌的密钥
# 注意：生产环境请设置强密钥
JWT_SECRET_KEY=

# Web 管理界面静态文件目录
# 默认：自动检测
# 说明：静态文件（HTML、CSS、JS）的存储目录
WEB_ADMIN_STATIC_FOLDER=

# Web 管理界面日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认：INFO
# 说明：Web 管理界面的日志级别
WEB_ADMIN_LOG_LEVEL=INFO

# Web 管理界面日志目录
# 默认：./logs
# 说明：Web 管理界面日志文件的存储目录
WEB_ADMIN_LOG_DIR=

# 是否启用速率限制
# 可选值：true, false
# 默认：true
# 说明：启用后限制 Web 管理界面的请求频率
WEB_ADMIN_RATE_LIMITING=true

# ============================================================
# XAgent 配置（可选）
# ============================================================
# Serper API Key（用于 XAgent 的网络搜索功能）
# 说明：获取 Serper API Key 需要在 https://serper.dev/ 注册账号
# 示例：SERPER_API_KEY=your_serper_api_key_here
SERPER_API_KEY=

# XAgent 工作目录
# 默认：~/.xagent
# 说明：XAgent 的工作目录，用于存储记忆、技能等数据
# XAGENT_WORKING_DIR=

# XAgent 内存压缩配置
# XAGENT_MEMORY_COMPACT_KEEP_RECENT=3
# XAGENT_MEMORY_COMPACT_RATIO=0.7

# XAgent 浏览器配置
# XAGENT_BROWSER_USE_DEFAULT=false

# XAgent 重载模式（Windows 平台）
# XAGENT_RELOAD_MODE=0

# 是否启用 XAgent 功能
# 默认：true
# 可选值：true, false
AGENT_ENABLED=true
